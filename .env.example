# === Deployment target ===
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
STAGING_BUCKET=gs://your-project-id-agent-staging

# Auto-filled by deploy.sh after the first successful deploy. Leave empty to
# create a new Agent Runtime instance; once set, redeploys update this same
# instance (new revision) instead of creating a new one. Clear this value to
# force a brand new instance on the next deploy.
AGENT_ENGINE_ID=

# === Container resources (Agent Runtime) ===
# cpu: one of 1, 2, 4, 6, 8
# memory: 1Gi..32Gi — must pair with a compatible cpu value, see
# https://cloud.google.com/run/docs/configuring/memory-limits
# Bump AGENT_MEMORY if your skill processes large file uploads — the
# container is silently OOM-killed (no error log) if it runs out of memory.
AGENT_CPU=
AGENT_MEMORY=

# === Model ===
MODEL_LOCATION=global
MODEL=gemini-3.5-flash
THINKING_LEVEL=MEDIUM

# === Agent behavior ===
SCRIPT_TIMEOUT_SECONDS=60
# SKILL_DIR=skill  # override only for testing
