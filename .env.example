# === Deployment target ===
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
STAGING_BUCKET=gs://your-project-id-agent-staging

# Auto-filled by deploy.sh after the first successful deploy. Leave empty to
# create a new Agent Runtime instance; once set, redeploys update this same
# instance (new revision) instead of creating a new one. Clear this value to
# force a brand new instance on the next deploy.
AGENT_ENGINE_ID=

# === Container resources (Agent Runtime) ===
# cpu: one of 1, 2, 4, 6, 8
# memory: 1Gi..32Gi — must pair with a compatible cpu value, see
# https://cloud.google.com/run/docs/configuring/memory-limits
# Bump AGENT_MEMORY if your skill processes large file uploads — the
# container is silently OOM-killed (no error log) if it runs out of memory.
AGENT_CPU=
AGENT_MEMORY=

# extract_pdf_text.py parallelizes page extraction across worker processes. Set this
# to match AGENT_CPU above (or lower, to leave headroom for the rest of the agent) —
# it is NOT auto-derived from AGENT_CPU, since AGENT_CPU is a deploy-time-only value
# that deploy.sh strips out before forwarding .env into the running container, and
# os.cpu_count() inside the container reads the host machine's CPU count, not the
# container's actual quota, so it can't be relied on to guess correctly. Each worker
# holds its own copy of the PDF in memory, so more workers also means more memory —
# tune alongside AGENT_MEMORY for large files, not CPU alone.
PDF_EXTRACT_WORKERS=4

# === Model ===
MODEL_LOCATION=global
MODEL=gemini-3.5-flash
THINKING_LEVEL=MEDIUM

# === Agent behavior ===
# extract_pdf_text.py is instructed to process PDFs in ~20-page chunks to stay well
# under this timeout (see skill/SKILL.md §0.4). Raising this number doesn't remove
# the need to chunk, since the user sees nothing while a script runs — it's headroom
# for genuinely slow chunks (dense tables, large pages), not a substitute for chunking.
SCRIPT_TIMEOUT_SECONDS=300
# SKILL_DIR=skill  # override only for testing
